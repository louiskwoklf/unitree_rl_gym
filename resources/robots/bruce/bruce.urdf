  <link name="shoulder_roll_link_l">
    <inertial>
      <origin xyz="0.057094 0.004195 0.000942" rpy="0 0 0"/>
      <mass value="0.0313652"/>
      <inertia ixx="1.013e-05" ixy="9.02e-06" ixz="3.42e-06"
               iyy="0.00016409" iyz="1.5e-07" izz="0.00016491"/>
    </inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="meshes/shoulder_roll_link_l.STL"/></geometry></visual>
