      <origin xyz="0.021788 0 0.00036" rpy="0 0 0"/>
      <mass value="0.0524404"/>
      <inertia ixx="7.53e-06" ixy="0" ixz="1.8e-07"
               iyy="7.261e-05" iyz="0" izz="7.103e-05"/>
    </inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="meshes/elbow_pitch_link_l.STL"/></geometry></visual>
