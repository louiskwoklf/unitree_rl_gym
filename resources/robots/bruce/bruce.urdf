  </joint>

  <joint name="ankle_pitch_l" type="revolute">
    <origin xyz="0.199881 0 0" rpy="0 0 0"/>
    <parent link="knee_pitch_link_l"/>
    <child link="ankle_pitch_link_l"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.50" upper="1.50" effort="10.5" velocity="20.0"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>

  <!-- ======================= -->
  <!-- Joints: Right arm -->
  <!-- ======================= -->
  <joint name="shoulder_pitch_r" type="revolute">
    <origin xyz="0.029216 -0.12375 0.152985" rpy="1.5708 -1.5708 0"/>
    <parent link="base_link"/>
    <child link="shoulder_pitch_link_r"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159265359" upper="3.14159265359" effort="10.5" velocity="20.0"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>

  <joint name="shoulder_roll_r" type="revolute">
    <origin xyz="0 0 0" rpy="1.5708 -1.5708 0"/>
    <parent link="shoulder_pitch_link_r"/>
    <child link="shoulder_roll_link_r"/>
    <axis xyz="0 0 1"/>
    <!-- From BRUCE_macros.py mapping: right roll in [-SHOULDER_ROLL_MAX, -SHOULDER_ROLL_MIN] = [-pi/2, +1.9] -->
    <limit lower="-1.57079632679" upper="1.90" effort="10.5" velocity="20.0"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>

  <joint name="elbow_pitch_r" type="revolute">
    <origin xyz="0.1146 -0.005 0.005" rpy="1.5708 0 0"/>
    <parent link="shoulder_roll_link_r"/>
    <child link="elbow_pitch_link_r"/>
    <axis xyz="0 0 1"/>
    <!-- Macros defines ELBOW_YAW limits; SDF joint is elbow_pitch. Using macros bounds as the policy/URDF bounds. -->
    <limit lower="-2.30" upper="2.30" effort="10.5" velocity="20.0"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>

  <!-- ======================= -->
  <!-- Joints: Left arm -->
  <!-- ======================= -->
  <joint name="shoulder_pitch_l" type="revolute">
    <origin xyz="0.029216 0.12375 0.152985" rpy="-1.5708 1.5708 0"/>
    <parent link="base_link"/>
    <child link="shoulder_pitch_link_l"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159265359" upper="3.14159265359" effort="10.5" velocity="20.0"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>

  <joint name="shoulder_roll_l" type="revolute">
    <origin xyz="0 0 0" rpy="1.5708 -1.5708 0"/>
    <parent link="shoulder_pitch_link_l"/>
    <child link="shoulder_roll_link_l"/>
    <axis xyz="0 0 1"/>
    <!-- Left roll in [SHOULDER_ROLL_MIN, SHOULDER_ROLL_MAX] = [-1.9, +pi/2] -->
    <limit lower="-1.90" upper="1.57079632679" effort="10.5" velocity="20.0"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>

  <joint name="elbow_pitch_l" type="revolute">
    <origin xyz="0.1146 0.005 0.005" rpy="-1.5708 0 0"/>
    <parent link="shoulder_roll_link_l"/>
    <child link="elbow_pitch_link_l"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.30" upper="2.30" effort="10.5" velocity="20.0"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>

