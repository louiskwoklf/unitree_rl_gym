  <!-- ======================= -->
  <!-- Joints: Right leg -->
  <!-- ======================= -->
  <joint name="hip_yaw_r" type="revolute">
    <origin xyz="0.029216 -0.075856 -0.039765" rpy="0 0 -1.5708"/>
    <parent link="base_link"/>
    <child link="hip_yaw_link_r"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57079632679" upper="1.57079632679" effort="10.5" velocity="20.0"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>

  <joint name="hip_pitch_r" type="revolute">
    <origin xyz="0 0 0" rpy="0 1.5708 0"/>
    <parent link="hip_yaw_link_r"/>
    <child link="hip_pitch_link_r"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.40" upper="2.50" effort="10.5" velocity="20.0"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>

  <joint name="hip_roll_r" type="revolute">
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <parent link="hip_pitch_link_r"/>
    <child link="hip_roll_link_r"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.78539816339" upper="0.78539816339" effort="10.5" velocity="20.0"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>

  <joint name="knee_pitch_r" type="revolute">
    <origin xyz="0.204949 0 0" rpy="1.5708 0 0"/>
    <parent link="hip_roll_link_r"/>
    <child link="knee_pitch_link_r"/>
    <axis xyz="0 0 1"/>
    <!-- intersection(SDF, macros): lower=max(-3.1415, -2.50)=-2.50; upper=min(-0.01, 0.0)=-0.01 -->
    <limit lower="-2.50" upper="-0.01" effort="10.5" velocity="20.0"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>

  <joint name="ankle_pitch_r" type="revolute">
    <origin xyz="0.199881 0 0" rpy="0 0 0"/>
    <parent link="knee_pitch_link_r"/>
    <child link="ankle_pitch_link_r"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.50" upper="1.50" effort="10.5" velocity="20.0"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>

  <!-- ======================= -->
  <!-- Joints: Left leg -->
  <!-- ======================= -->
  <joint name="hip_yaw_l" type="revolute">
    <origin xyz="0.029216 0.075856 -0.039765" rpy="0 0 -1.5708"/>
    <parent link="base_link"/>
    <child link="hip_yaw_link_l"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57079632679" upper="1.57079632679" effort="10.5" velocity="20.0"/>
