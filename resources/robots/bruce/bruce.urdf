<?xml version="1.0"?>
<!--
  BRUCE URDF (hand-written, "from scratch")

  Policy / modeling choices (per your “Bottom Line”):
  - Kinematic tree, joint frames, link inertials, meshes: taken from model.sdf
  - Joint position limits + effort limits: taken from BRUCE_macros.py (or intersection when SDF is tighter)
    * Knee upper uses SDF -0.01 (tighter than macros 0.0) to avoid fully-straight singularity.
    * Effort uses TORQUE_MAX = 10.5 Nm as a conservative actuator cap for RL.
  - Joint damping: copied from SDF (0.002)
  - Velocity limits: NOT provided in your sources; set to a conservative placeholder (20 rad/s).
    Replace with motor-spec values if you have them (or override in Isaac DOF props).

  Mesh paths:
  - Update the filenames to whatever Isaac Gym can resolve (e.g., absolute, relative, or package://).
-->

<robot name="bruce">

  <!-- ======================= -->
  <!-- Base -->
  <!-- ======================= -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.022596 -0.000113 0.061401" rpy="0 0 0"/>
      <mass value="1.31689"/>
      <inertia ixx="0.0133543" ixy="-3.36e-06" ixz="0.00182725"
               iyy="0.0102363" iyz="-1.163e-05" izz="0.005471"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/base_link.STL"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/base_link.STL"/></geometry>
    </collision>
  </link>

  <!-- ======================= -->
  <!-- Right leg links -->
  <!-- ======================= -->
  <link name="hip_yaw_link_r">
